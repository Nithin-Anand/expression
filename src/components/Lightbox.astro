---

---

<dialog
    id="lightbox"
    class="backdrop:bg-black/90 bg-transparent p-0 w-full h-full max-w-none max-h-none m-0 outline-none overflow-hidden"
>
    <div
        id="lightbox-content"
        class="relative w-full h-full flex items-center justify-center"
    >
        <button
            id="lightbox-close"
            class="absolute top-4 right-4 z-50 p-2 text-white/70 hover:text-white transition-colors cursor-pointer drop-shadow-md"
            aria-label="Close lightbox"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
        </button>
        <button
            id="lightbox-prev"
            class="absolute left-4 top-1/2 -translate-y-1/2 z-50 p-2 text-white/70 hover:text-white transition-colors cursor-pointer drop-shadow-md"
            aria-label="Previous photo"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="32"
                height="32"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
        </button>
        <button
            id="lightbox-next"
            class="absolute right-4 top-1/2 -translate-y-1/2 z-50 p-2 text-white/70 hover:text-white transition-colors cursor-pointer drop-shadow-md"
            aria-label="Next photo"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="32"
                height="32"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
        </button>
        <img
            id="lightbox-img"
            src=""
            alt=""
            class="max-w-[90vw] max-h-[90vh] object-contain shadow-2xl rounded-sm"
        />
    </div>
</dialog>

<script>
    const dialog = document.getElementById("lightbox") as HTMLDialogElement;
    const closeBtn = document.getElementById("lightbox-close");
    const prevBtn = document.getElementById("lightbox-prev");
    const nextBtn = document.getElementById("lightbox-next");
    const lightboxImg = document.getElementById(
        "lightbox-img",
    ) as HTMLImageElement;
    const lightboxContent = document.getElementById("lightbox-content");

    // The ordered set of navigable photos on the page and the current position.
    let galleryImages: HTMLElement[] = [];
    let currentIndex = -1;

    // Render the photo at the given index (reuses the data-lightbox-webp + alt
    // convention shared by every thumbnail).
    const showImageAt = (index: number) => {
        const el = galleryImages[index];
        if (!el) return;

        // Use WebP (best Safari compatibility)
        const webpSrc = el.getAttribute("data-lightbox-webp");
        if (!webpSrc) return;

        currentIndex = index;
        lightboxImg.src = webpSrc;
        lightboxImg.alt = (el as HTMLImageElement).alt || "";
    };

    // Move by dir (-1 = previous, +1 = next), wrapping around at the ends.
    const navigate = (dir: number) => {
        if (currentIndex === -1 || galleryImages.length === 0) return;
        const n = galleryImages.length;
        showImageAt((currentIndex + dir + n) % n);
    };

    // Open lightbox
    document.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;
        const trigger = target.closest("[data-lightbox]");

        if (trigger) {
            e.preventDefault();

            // Build the ordered set from the live DOM and locate the clicked photo.
            galleryImages = Array.from(
                document.querySelectorAll<HTMLElement>("[data-lightbox]"),
            );
            currentIndex = galleryImages.indexOf(trigger as HTMLElement);

            if (currentIndex !== -1) {
                showImageAt(currentIndex);
                dialog.showModal();
                document.body.style.overflow = "hidden"; // Prevent scrolling

                // Hide arrows when there's only one photo on the page.
                const single = galleryImages.length <= 1;
                prevBtn?.classList.toggle("hidden", single);
                nextBtn?.classList.toggle("hidden", single);
            }
        }
    });

    // Close lightbox functions
    const closeLightbox = () => {
        dialog.close();
        lightboxImg.src = "";
        currentIndex = -1;
        galleryImages = [];
        document.body.style.overflow = ""; // Restore scrolling
    };

    closeBtn?.addEventListener("click", closeLightbox);
    prevBtn?.addEventListener("click", () => navigate(-1));
    nextBtn?.addEventListener("click", () => navigate(1));

    // Keyboard controls while the lightbox is open.
    document.addEventListener("keydown", (e) => {
        if (!dialog.open) return;
        if (e.key === "ArrowLeft") {
            e.preventDefault();
            navigate(-1);
        } else if (e.key === "ArrowRight") {
            e.preventDefault();
            navigate(1);
        } else if (e.key === "Escape") {
            // Route Escape through closeLightbox so scroll/state are always
            // restored — the native dialog "close" event is unreliable here.
            e.preventDefault();
            closeLightbox();
        }
    });

    // Touch swipe (mobile)
    let touchStartX = 0;
    lightboxContent?.addEventListener(
        "touchstart",
        (e) => {
            touchStartX = e.changedTouches[0].screenX;
        },
        { passive: true },
    );
    lightboxContent?.addEventListener(
        "touchend",
        (e) => {
            const dx = e.changedTouches[0].screenX - touchStartX;
            if (Math.abs(dx) > 50) navigate(dx < 0 ? 1 : -1); // 50px threshold
        },
        { passive: true },
    );

    // Close on backdrop click
    dialog.addEventListener("click", (e) => {
        // Since the dialog is now full screen, we check if the click target is
        // the dialog itself or the flex container (empty space around image)
        if (e.target === dialog || e.target === lightboxContent) {
            closeLightbox();
        }
    });

    // Safety net: if the dialog is closed by any other path, reset state and
    // restore scrolling. (Escape and the close button already go through
    // closeLightbox; this "close" event does not always fire in Chrome.)
    dialog.addEventListener("close", () => {
        currentIndex = -1;
        galleryImages = [];
        document.body.style.overflow = "";
    });
</script>

<style>
    dialog::backdrop {
        background: rgba(0, 0, 0, 0.9);
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
    }

    dialog[open] {
        animation: fade-in 0.2s ease-out;
    }

    @keyframes fade-in {
        from {
            opacity: 0;
            transform: scale(0.95);
        }
        to {
            opacity: 1;
            transform: scale(1);
        }
    }
</style>
